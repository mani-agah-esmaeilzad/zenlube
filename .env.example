# Core
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
NEXTAUTH_SECRET="change-me"
NEXTAUTH_URL="https://www.oilbar.ir"
NEXT_PUBLIC_APP_URL="https://www.oilbar.ir"

# Payment: Zarinpal
ZARINPAL_MERCHANT_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
ZARINPAL_BASE_URL="https://api.zarinpal.com/pg/v4"
ZARINPAL_STARTPAY_URL="https://www.zarinpal.com/pg/StartPay"
# Optional. If empty, app uses NEXT_PUBLIC_APP_URL + /api/payments/zarinpal/callback
ZARINPAL_CALLBACK_URL=""
# Product/order prices are stored as toman by default. Set rial only if your gateway account expects rial.
ZARINPAL_AMOUNT_UNIT="toman"

# SMS
# Providers: smsir, melipayamak, console, disabled
SMS_ENABLED="false"
SMS_SANDBOX_MODE="true"
SMS_PROVIDER="console"
SMS_API_KEY=""
SMS_SENDER_NUMBER=""

# sms.ir OTP template support
SMSIR_API_KEY=""
SMSIR_LINE_NUMBER=""
SMSIR_TEMPLATE_ID=""
SMSIR_TEMPLATE_CODE_PARAM="CODE"
SMSIR_TEMPLATE_EXPIRY_PARAM=""

# Melipayamak
MELIPAYAMAK_USERNAME=""
MELIPAYAMAK_PASSWORD=""
MELIPAYAMAK_FROM=""
MELIPAYAMAK_ENDPOINT="https://console.melipayamak.com/api/send/otp"

# Optional storage
STORAGE_DRIVER="local"
STORAGE_BUCKET=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION=""

# Security / rate limits
CRON_SECRET=""
HCAPTCHA_SECRET=""
OTP_RATE_LIMIT_WINDOW="300"
OTP_RATE_LIMIT_MAX="5"
OTP_RESEND_WINDOW_SECONDS="20"
QUESTION_RATE_LIMIT_WINDOW="900"
QUESTION_RATE_LIMIT_MAX="3"
